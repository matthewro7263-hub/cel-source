# ---- App ----
NODE_ENV=development
PORT=3000

# ---- Database (Postgres for Drizzle) ----
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/cel_source

# ---- Sessions / Auth ----
# Generate a strong random string (e.g. `openssl rand -hex 32`)
SESSION_SECRET=replace-with-a-long-random-string

# ---- Cloudflare R2 (S3-compatible) ----
# Bucket: cel-source-uploads (private)
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_BUCKET=cel-source-uploads
R2_ENDPOINT=https://YOUR_CLOUDFLARE_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=REPLACE_WITH_YOUR_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_SECRET_ACCESS_KEY

# Optional: a Cloudflare API token (only if you call the CF API directly)
# R2_TOKEN=

# ---- CORS ----
# Comma-separated list of allowed frontend origins in production
# e.g. ALLOWED_ORIGINS=https://your-app.onrender.com,https://www.yourapp.com
ALLOWED_ORIGINS=
